	<DiceMasterUnitCard name="DiceMasterUnitCardDragDummy" parent="UIParent" frameStrata="HIGH" hidden="true">
		<Scripts>
			<OnUpdate>
				if self:IsShown() then
					self:ClearAllPoints();
					local x, y = GetCursorPosition();
					local s = self:GetEffectiveScale();
					self:SetPoint("CENTER", "UIParent", "BOTTOMLEFT", (x / s), (y / s));
				end
			</OnUpdate>
			<OnMouseUp>
				self:Hide();
				for card in DiceMasterInitiativeBar.Cards:EnumerateActive() do
					if card:GetID() == self:GetID() then
						card:SetAlpha( 1 );
						break
					end
				end
				self:SetID(0);
			</OnMouseUp>
		</Scripts>
	</DiceMasterUnitCard>

